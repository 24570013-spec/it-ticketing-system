PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ticketing_db

# Ganti dengan secret yang kuat!
JWT_SECRET=your_very_long_random_secret_here
REFRESH_TOKEN_SECRET=another_very_long_random_secret

NODE_ENV=production

# Ganti dengan URL Vercel kamu (contoh: https://ticketing-abc.vercel.app)
CORS_ORIGIN=https://YOUR_APP.vercel.app

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@ticketing.com
