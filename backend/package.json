    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.9.7",
    "nodemailer": "^8.0.11"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "fast-check": "^3.19.0",
